{
  "name": "x-download-video",
  "version": "1.0",
  "description": "Download videos from X",
  "manifest_version": 3,
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "permissions": ["storage", "downloads", "declarativeNetRequest"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://api.vxtwitter.com/*",
    "https://api.fxtwitter.com/*",
    "https://d.fixupx.com/*",
    "https://d.fxtwitter.com/*",
    "https://video.twimg.com/*",
    "https://pbs.twimg.com/*",
    "https://abs.twimg.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "rules_remove_frame_options",
        "enabled": true,
        "path": "rules_remove_frame_options.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": [
        "insert.js",
        "content.css"
      ],
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ]
    }
  ],
  "action": {
    "default_popup": "index.html",
    "default_title": "x-download-video",
    "default_icon": {
      "16": "images/icon-16.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}